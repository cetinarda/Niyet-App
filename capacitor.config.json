{
  "appId": "app.sakin.life",
  "appName": "Sakin",
  "webDir": "dist",
  "server": {
    "iosScheme": "capacitor"
  },
  "ios": {
    "contentInset": "automatic",
    "backgroundColor": "#000000",
    "preferredContentMode": "mobile"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": false,
      "backgroundColor": "#000000",
      "showSpinner": false
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_sakin",
      "iconColor": "#ffffff"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#000000"
    }
  }
}
