{
  "appId": "app.sakin.life",
  "appName": "Sakin",
  "webDir": "dist",
  "server": {
    "iosScheme": "capacitor"
  },
  "ios": {
    "contentInset": "automatic",
    "backgroundColor": "#080c14",
    "preferredContentMode": "mobile"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": false,
      "backgroundColor": "#080c14",
      "showSpinner": false
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_sakin",
      "iconColor": "#8B5AA0"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#080c14"
    }
  }
}
